# Required for Chainlit authentication. Use a long random value in production.
CHAINLIT_AUTH_SECRET=replace-with-a-long-random-secret

# Initial admin account. The backend ensures this user exists on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Coze configuration. These can also be configured from /admin after login.
COZE_BASE_URL=https://api.coze.cn
# COZE_BOT_ID is used by the Daily_Practice_Agent workflow and as the fallback
# for teaching agents whose dedicated Bot IDs are left empty.
COZE_BOT_ID=
COZE_BOT_ID_NOVICE=
COZE_BOT_ID_DEBATE=
COZE_BOT_ID_EXPERT=
COZE_JWT_TOKEN=
COZE_JWT_EXPIRES_AT=

# Host port for docker compose.
LINGXI_PORT=8123
